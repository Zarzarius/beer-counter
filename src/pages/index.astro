---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Welcome">
  <div class="container hero-container">
    <div class="glass-panel hero-panel text-center">
      <div class="icon-wrapper">
        <img src="/logo.webp" alt="Beer Tab Logo" class="brand-logo" width="128" height="128" />
      </div>
      <h1>Welcome to Beer Tab</h1>
      <p class="subtitle">Keep track of your drinks and easily settle your bar tab.</p>
      
      <div class="action-buttons">
        <a href="/login" class="btn-primary">
          Open Your Tab
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .hero-container {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }
  
  .hero-panel {
    padding: 3rem 2rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  
  .text-center {
    text-align: center;
  }

  .icon-wrapper {
    width: 90px;
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
  }

  .brand-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #fff 0%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1.125rem;
    max-width: 400px;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .action-buttons {
    display: flex;
    gap: 1rem;
    width: 100%;
    margin-top: 1rem;
  }

  .action-buttons > a {
    flex: 1;
  }
</style>
