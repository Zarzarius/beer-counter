---
import Layout from '../layouts/Layout.astro';
---

<Layout title="QR Scanner">
  <div class="container hero-container text-center">
    <!-- This page acts as the target for the physical QR code -->
    <div class="glass-panel hero-panel animate-fade-in">
      <div class="icon-wrapper">
        <img src="/logo.webp" alt="Beer Tab Logo" class="brand-logo" width="128" height="128" />
      </div>
      <h2>Scanning Table…</h2>
      <p>Redirecting you to your tab.</p>
      
      <div class="spinner"></div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  // Check if the user is already logged in
  supabase.auth.getSession().then(({ data: { session } }) => {
    setTimeout(() => {
      if (session) {
        window.location.href = '/customer';
      } else {
        // Redirect to login, but could pass a 'next' param if needed
        window.location.href = '/login?next=/customer';
      }
    }, 1500); // Small delay for UX so they see the scanning animation
  });
</script>

<style>
  .hero-container {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }
  
  .hero-panel {
    padding: 3rem 2rem;
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  
  .text-center {
    text-align: center;
  }

  .icon-wrapper {
    width: 90px;
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .brand-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--text-secondary);
  }

  .spinner {
    margin-top: 1.5rem;
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    border-top-color: var(--brand-primary);
    animation: spin 1s ease-in-out infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
