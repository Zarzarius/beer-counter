---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Manager Dashboard">
  <div class="container manager-dashboard" style="max-width: 900px;">
    <header class="dashboard-header animate-fade-in">
      <div class="header-left">
        <h2>Manager Dashboard</h2>
        <p class="subtitle">Overview of all customer tabs</p>
      </div>
      <button id="logout-btn" class="btn-secondary btn-sm">Sign Out</button>
    </header>

    <div class="glass-panel stats-panel animate-fade-in" style="animation-delay: 0.1s;">
      <div class="stat-box">
        <span class="stat-label">Active Customers</span>
        <span class="stat-value" id="stat-customers">--</span>
      </div>
      <div class="stat-box border-left">
        <span class="stat-label">Unpaid Drinks</span>
        <span class="stat-value" id="stat-unpaid">--</span>
      </div>
      <div class="stat-box border-left">
        <span class="stat-label">Today's Drinks</span>
        <span class="stat-value" id="stat-today">--</span>
      </div>
    </div>

    <div class="users-list animate-fade-in" style="animation-delay: 0.2s;">
      <h3>Customer Tabs</h3>
      <div id="tabs-container">
        <div class="loading-state text-center" style="padding: 2rem;">Loading tabs...</div>
      </div>
    </div>
  </div>

  <!-- Edit Beer Modal -->
  <div id="edit-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content glass-panel animate-scale-up">
      <div class="modal-header">
        <h3>Edit Drink</h3>
        <button id="close-modal" class="btn-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <form id="edit-beer-form" class="edit-form">
        <input type="hidden" id="edit-beer-id">
        <div class="input-group">
          <label for="edit-beer-name" class="input-label">Name</label>
          <input type="text" id="edit-beer-name" class="input-field" required>
        </div>
        <div class="input-group">
          <label for="edit-beer-notes" class="input-label">Notes</label>
          <textarea id="edit-beer-notes" class="input-field" rows="3"></textarea>
        </div>
        <div class="checkbox-group">
          <input type="checkbox" id="edit-beer-paid" class="checkbox-input">
          <label for="edit-beer-paid" class="checkbox-label">Mark as Paid</label>
        </div>
        <div class="modal-actions">
          <button type="button" id="delete-beer-btn" class="btn-danger-outline btn-sm">Delete</button>
          <div class="flex-grow"></div>
          <button type="submit" class="btn-primary btn-sm">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  console.log('[Manager] Script loaded');
  const logoutBtn = document.getElementById('logout-btn');
  const tabsContainer = document.getElementById('tabs-container');
  const statUnpaid = document.getElementById('stat-unpaid');
  const statToday = document.getElementById('stat-today');
  const statCustomers = document.getElementById('stat-customers');

  async function init() {
    console.log('[Manager] init() called');
    const { data: { session } } = await supabase.auth.getSession();
    console.log('[Manager] Session found:', !!session);
    if (!session) { window.location.href = '/login'; return; }

    console.log('[Manager] Fetching profile...');
    const { data: profile } = await supabase
      .from('profiles').select('role').eq('id', session.user.id).single();
    console.log('[Manager] Profile role:', profile?.role);

    if (profile?.role !== 'manager') { 
      console.warn('[Manager] Access denied: not a manager');
      window.location.href = '/customer'; 
      return; 
    }

    console.log('[Manager] Loading dashboard data...');
    try {
      await loadDashboard();
      console.log('[Manager] Dashboard loaded');
    } catch (err) {
      console.error('[Manager] Dashboard load failed:', err);
    }

    // Realtime: refresh manager dashboard on any beer change
    console.log('[Realtime] Setting up manager subscription...');
    supabase
      .channel('manager-beers')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'beers' }, (payload) => {
        console.log('[Realtime] MANAGER RECEIVED CHANGE:', payload);
        loadDashboard();
      })
      .subscribe((status, err) => {
        console.log('[Realtime] Manager subscription status:', status);
        if (err) console.error('[Realtime] Manager subscription error:', err);
      });
  }

  async function loadDashboard() {
    const { data: profiles } = await supabase
      .from('profiles').select('id, email, role, full_name').eq('role', 'customer');
    const { data: beers } = await supabase
      .from('beers').select('*').order('created_at', { ascending: false });

    if (!tabsContainer) return;

    const allBeers = beers || [];
    const allProfiles = profiles || [];

    const unpaidCount = allBeers.filter(b => !b.is_paid).length;
    const todayCount = allBeers.filter(b => new Date(b.created_at).toDateString() === new Date().toDateString()).length;
    const activeCustomers = allProfiles.filter(p => allBeers.some(b => b.user_id === p.id)).length;

    if (statUnpaid) statUnpaid.textContent = unpaidCount.toString();
    if (statToday) statToday.textContent = todayCount.toString();
    if (statCustomers) statCustomers.textContent = activeCustomers.toString();

    const customersWithBeers = allProfiles.filter(p => allBeers.some(b => b.user_id === p.id));

    if (customersWithBeers.length === 0) {
      tabsContainer.innerHTML = '<div class="glass-panel text-center" style="padding: 2rem; color: var(--text-secondary);">No drink history yet.</div>';
      return;
    }

    let html = '';

    customersWithBeers.forEach(profile => {
      const userBeers = allBeers.filter(b => b.user_id === profile.id);
      
      // Group by name + paid status
      type GroupData = { name: string; notes: string; items: any[]; is_paid: boolean; };
      const groups: Record<string, GroupData> = {};
      userBeers.forEach(b => {
        const key = `${b.name.toLowerCase()}::${b.is_paid}`;
        if (groups[key]) {
          groups[key].items.push(b);
        } else {
          groups[key] = { name: b.name, notes: b.notes || '', items: [b], is_paid: b.is_paid };
        }
      });

      const groupList = Object.values(groups).sort((a, b) => a.is_paid ? 1 : -1);
      const unpaidGroups = groupList.filter(g => !g.is_paid);
      const paidGroups = groupList.filter(g => g.is_paid);
      const unpaidTotal = unpaidGroups.reduce((s, g) => s + g.items.length, 0);
      const paidTotal = paidGroups.reduce((s, g) => s + g.items.length, 0);
      const hasUnpaid = unpaidTotal > 0;

      const renderGroup = (g: GroupData, groupIndex: number, sectionType: string) => {
        const groupId = `group-${profile.id.substring(0,4)}-${sectionType}-${groupIndex}`;
        return `
        <div class="beer-group-container" id="${groupId}">
          <div class="beer-mini-row ${g.is_paid ? 'is-paid' : 'is-unpaid'} group-header" data-toggle-group="${groupId}">
            <div class="beer-mini-left">
              <span class="beer-mini-name">${g.name}</span>
              ${g.notes ? `<span class="beer-mini-notes">${g.notes}</span>` : ''}
              <span class="expand-hint">Click to manage individual items</span>
            </div>
            <span class="beer-mini-count ${g.is_paid ? 'count-paid' : 'count-unpaid'}">×${g.items.length}</span>
          </div>
          <div class="beer-group-items" style="display: none;">
            ${g.items.map(item => `
              <div class="individual-beer-row" data-id="${item.id}">
                <div class="item-meta">
                  <span class="item-time">${new Date(item.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                  <span class="item-date">${new Date(item.created_at).toLocaleDateString([], { month: 'short', day: 'numeric' })}</span>
                </div>
                <div class="item-actions">
                  <button class="btn-icon btn-edit" 
                          data-id="${item.id}" 
                          data-name="${item.name.replace(/"/g, '&quot;')}" 
                          data-notes="${(item.notes || '').replace(/"/g, '&quot;')}" 
                          data-paid="${item.is_paid}"
                          title="Edit drink">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                  </button>
                  <button class="btn-toggle-status ${item.is_paid ? 'btn-unpay' : 'btn-pay'}" data-id="${item.id}" data-current="${item.is_paid}" title="${item.is_paid ? 'Mark Unpaid' : 'Mark Paid'}">
                    ${item.is_paid 
                      ? `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>`
                      : `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`
                    }
                  </button>
                </div>
              </div>
            `).join('')}
          </div>
        </div>`;
      };

      html += `
        <div class="glass-panel user-tab-card ${!hasUnpaid ? 'all-settled' : ''}">
          <div class="user-tab-header">
            <div class="user-tab-info">
              <h4>${profile.full_name || profile.email}</h4>
              ${profile.full_name ? `<span class="user-email-sub">${profile.email}</span>` : ''}
              <div class="tab-pills">
                ${unpaidTotal > 0 ? `<span class="tab-pill pill-unpaid">${unpaidTotal} unpaid</span>` : ''}
                ${paidTotal > 0 ? `<span class="tab-pill pill-paid">${paidTotal} paid</span>` : ''}
                <span class="tab-pill pill-total">${unpaidTotal + paidTotal} total</span>
              </div>
            </div>
            ${hasUnpaid
              ? `<button class="btn-primary btn-sm mark-paid-btn" data-userid="${profile.id}">Mark All Paid</button>`
              : `<span class="badge badge-success">✓ Settled</span>`
            }
          </div>
          <div class="user-tab-body">
            ${unpaidGroups.length > 0 ? `
              <div class="beer-section">
                <div class="beer-section-label unpaid-label">On Tab</div>
                ${unpaidGroups.map((g, i) => renderGroup(g, i, 'unpaid')).join('')}
              </div>` : ''}
            ${paidGroups.length > 0 ? `
              <div class="beer-section ${unpaidGroups.length > 0 ? 'section-divider' : ''}">
                <div class="beer-section-label paid-label">Paid</div>
                ${paidGroups.map((g, i) => renderGroup(g, i, 'paid')).join('')}
              </div>` : ''}
          </div>
        </div>`;
    });

    tabsContainer.innerHTML = html;

    // Expand/Collapse Group Logic
    document.querySelectorAll('.group-header').forEach(header => {
      header.addEventListener('click', (e) => {
        const groupId = header.getAttribute('data-toggle-group');
        if (!groupId) return;
        const groupContainer = document.getElementById(groupId);
        const itemsList = groupContainer?.querySelector('.beer-group-items') as HTMLElement;
        if (itemsList) {
          const isHidden = itemsList.style.display === 'none';
          itemsList.style.display = isHidden ? 'flex' : 'none';
          header.classList.toggle('is-expanded', isHidden);
        }
      });
    });

    // Mark All Paid
    document.querySelectorAll('.mark-paid-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const userId = (e.target as HTMLElement).getAttribute('data-userid') ?? '';
        if (!userId) return;
        const el = e.target as HTMLButtonElement;
        el.textContent = 'Processing...';
        el.disabled = true;
        try {
          const { error } = await supabase.from('beers').update({ is_paid: true }).eq('user_id', userId).eq('is_paid', false);
          if (error) throw error;
          await loadDashboard();
        } catch (err) {
          alert('Error updating database');
          el.textContent = 'Mark All Paid';
          el.disabled = false;
        }
      });
    });

    // Individual Toggle Status
    document.querySelectorAll('.btn-toggle-status').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).getAttribute('data-id') ?? '';
        const currentStatus = (btn as HTMLElement).getAttribute('data-current') === 'true';
        
        try {
          const { error } = await supabase.from('beers').update({ is_paid: !currentStatus }).eq('id', id);
          if (error) throw error;
          await loadDashboard();
        } catch (err) {
          alert('Error toggling status');
        }
      });
    });

    // Edit Modal Logic
    const editModal = document.getElementById('edit-modal') as HTMLElement;
    const editForm = document.getElementById('edit-beer-form') as HTMLFormElement;
    const editIdInput = document.getElementById('edit-beer-id') as HTMLInputElement;
    const editNameInput = document.getElementById('edit-beer-name') as HTMLInputElement;
    const editNotesInput = document.getElementById('edit-beer-notes') as HTMLTextAreaElement;
    const editPaidInput = document.getElementById('edit-beer-paid') as HTMLInputElement;
    const closeModal = document.getElementById('close-modal');
    const deleteBtn = document.getElementById('delete-beer-btn');
    document.querySelectorAll('.btn-edit').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).getAttribute('data-id') ?? '';
        const name = (btn as HTMLElement).getAttribute('data-name') ?? '';
        const notes = (btn as HTMLElement).getAttribute('data-notes') ?? '';
        const isPaid = (btn as HTMLElement).getAttribute('data-paid') === 'true';
        
        editIdInput.value = id;
        editNameInput.value = name;
        editNotesInput.value = notes;
        editPaidInput.checked = isPaid;
        editModal.style.display = 'flex';
      });
    });

    closeModal?.addEventListener('click', () => editModal.style.display = 'none');
    
    editForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = editIdInput.value;
      const name = editNameInput.value;
      const notes = editNotesInput.value;
      const is_paid = editPaidInput.checked;
      
      try {
        const { error } = await supabase.from('beers').update({ name, notes, is_paid }).eq('id', id);
        if (error) throw error;
        editModal.style.display = 'none';
        await loadDashboard();
      } catch (err) {
        alert('Error saving changes');
      }
    });

    deleteBtn?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete this drink?')) return;
      const id = editIdInput.value;
      try {
        const { error } = await supabase.from('beers').delete().eq('id', id);
        if (error) throw error;
        editModal.style.display = 'none';
        await loadDashboard();
      } catch (err) {
        alert('Error deleting drink');
      }
    });
  }


  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  init();
</script>

<style>
  .manager-dashboard {
    padding-top: 2rem;
    padding-bottom: 4rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 1rem;
  }

  .header-left h2 { font-size: 1.75rem; margin-bottom: 0.25rem; }
  .subtitle { color: var(--text-secondary); font-size: 0.9rem; }

  .stats-panel { display: flex; padding: 0; overflow: hidden; }

  .stat-box {
    flex: 1;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
  }

  .border-left { border-left: 1px solid rgba(255, 255, 255, 0.07); }

  .stat-label {
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--brand-primary);
    line-height: 1;
  }

  .users-list h3 {
    margin-bottom: 1.25rem;
    font-size: 1.25rem;
    font-family: var(--font-heading);
  }

  #tabs-container { display: flex; flex-direction: column; gap: 1.25rem; }

  .user-tab-card { display: flex; flex-direction: column; overflow: hidden; }
  .user-tab-card.all-settled { opacity: 0.7; }

  .user-tab-header {
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    background: rgba(0, 0, 0, 0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .user-tab-info h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    margin-bottom: 0.4rem;
    color: #fff;
  }

  .tab-pills { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .tab-pill {
    padding: 0.15rem 0.6rem;
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 600;
  }

  .pill-unpaid {
    background: rgba(245, 158, 11, 0.15);
    color: var(--brand-primary);
    border: 1px solid rgba(245, 158, 11, 0.25);
  }

  .pill-paid {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
    border: 1px solid rgba(16, 185, 129, 0.25);
  }

  .pill-total {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn-sm { padding: 0.45rem 1rem; font-size: 0.85rem; white-space: nowrap; }

  .badge {
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .badge-success {
    background-color: rgba(16, 185, 129, 0.15);
    color: var(--success);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .user-tab-body {
    padding: 0.75rem 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .beer-section { display: flex; flex-direction: column; }
  .beer-section.section-divider {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 0.75rem;
    margin-top: 0.5rem;
  }

  .beer-section-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 0;
    margin-bottom: 0.15rem;
  }

  .unpaid-label { color: var(--brand-primary); }
  .paid-label { color: var(--text-secondary); }

  .beer-mini-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    gap: 1rem;
  }

  .beer-mini-row:last-child { border-bottom: none; }
  .beer-mini-row.is-paid { opacity: 0.45; }

  .beer-mini-left { display: flex; flex-direction: column; gap: 0.1rem; }
  .beer-mini-name { font-size: 0.95rem; color: #e2e8f0; }
  .beer-mini-notes { font-size: 0.78rem; color: var(--text-secondary); }

  .beer-mini-count {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .count-unpaid { color: var(--brand-primary); }
  .count-paid { color: var(--text-secondary); }

  .text-center { text-align: center; }
  .text-secondary { color: var(--text-secondary); }
</style>
