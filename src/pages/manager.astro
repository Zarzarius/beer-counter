---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Manager Dashboard">
  <div class="container manager-dashboard" style="max-width: 900px;">
    <header class="dashboard-header animate-fade-in">
      <div class="header-left">
        <h2>Manager Dashboard</h2>
        <p class="subtitle">Overview of all customer tabs</p>
      </div>
      <div class="header-right">
        <button id="open-stock-overlay-btn" class="btn-secondary btn-sm">Edit beer stock</button>
        <button id="logout-btn" class="btn-secondary btn-sm">Sign Out</button>
      </div>
    </header>

    <div class="glass-panel stats-panel animate-fade-in" style="animation-delay: 0.1s;">
      <div class="stat-box">
        <span class="stat-label">Active Customers</span>
        <span class="stat-value" id="stat-customers">--</span>
      </div>
      <div class="stat-box border-left">
        <span class="stat-label">Unpaid Drinks</span>
        <span class="stat-value" id="stat-unpaid">--</span>
      </div>
      <div class="stat-box border-left">
        <span class="stat-label" id="stat-today-label">Today's Drinks</span>
        <span class="stat-value" id="stat-today">--</span>
      </div>
    </div>

    <div id="day-navigator" class="day-navigator" hidden>
      <button type="button" id="day-prev" class="day-nav-btn day-prev" title="Previous day" aria-label="Previous day">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <div class="day-label-wrap">
        <span id="day-label" class="day-label">Today</span>
        <select id="day-select" class="day-select" aria-label="Select day">
          <option value="">Today</option>
        </select>
      </div>
      <button type="button" id="day-next" class="day-nav-btn day-next" title="Next day" aria-label="Next day">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>

    <div class="users-list animate-fade-in" style="animation-delay: 0.2s;">
      <h3>Customer Tabs</h3>
      <div id="tabs-container">
        <div class="loading-state text-center" style="padding: 2rem;" role="status" aria-live="polite">Loading tabs…</div>
      </div>
    </div>
  </div>

  <!-- Edit Beer Modal -->
  <div
    id="edit-modal"
    class="modal-overlay"
    style="display: none;"
    role="dialog"
    aria-modal="true"
    aria-labelledby="edit-modal-title"
  >
    <div class="modal-content glass-panel animate-scale-up">
      <div class="modal-header">
        <h3 id="edit-modal-title">Edit Drink</h3>
        <button id="close-modal" class="btn-icon" type="button" aria-label="Close edit drink modal">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <form id="edit-beer-form" class="edit-form">
        <input type="hidden" id="edit-beer-id">
        <div class="input-group">
          <label for="edit-beer-name" class="input-label">Name</label>
          <input type="text" id="edit-beer-name" class="input-field" required>
        </div>
        <div class="input-group">
          <label for="edit-beer-notes" class="input-label">Notes</label>
          <textarea id="edit-beer-notes" class="input-field" rows="3"></textarea>
        </div>
        <div class="checkbox-group">
          <input type="checkbox" id="edit-beer-paid" class="checkbox-input">
          <label for="edit-beer-paid" class="checkbox-label">Mark as Paid</label>
        </div>
        <div class="modal-actions">
          <button type="button" id="delete-beer-btn" class="btn-danger-outline btn-sm">Delete</button>
          <div class="flex-grow"></div>
          <button type="submit" class="btn-primary btn-sm">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Beer Stock Overlay -->
  <div
    id="stock-overlay"
    class="modal-overlay"
    style="display: none;"
    role="dialog"
    aria-modal="true"
    aria-labelledby="stock-overlay-title"
  >
    <div class="modal-content glass-panel large-modal">
      <div class="modal-header">
        <h3 id="stock-overlay-title">Beer stock</h3>
        <button id="close-stock-overlay" class="btn-icon" type="button" aria-label="Close beer stock overlay">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="stock-overlay-body">
        <div class="manager-controls stock-overlay-controls">
          <div class="manager-controls-row">
            <div class="input-group manager-search-group">
              <label for="catalog-search" class="input-label">Search catalog</label>
              <input
                id="catalog-search"
                type="text"
                class="input-field"
                placeholder="Search by name, brewery, or style…"
                autocomplete="off"
              />
            </div>
            <button id="add-beer-stock-btn" class="btn-primary btn-sm" type="button">Add New Beer</button>
          </div>
        </div>
        <div class="manager-table-panel stock-overlay-table">
          <div id="catalog-status" class="catalog-status" role="status" aria-live="polite">Loading catalog…</div>
          <div id="catalog-table-wrap" class="catalog-table-wrap" hidden>
            <table class="catalog-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Brewery</th>
                  <th>Style</th>
                  <th>Year</th>
                  <th>Available</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="catalog-table-body"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    <!-- Add/Edit stock modal (nested in overlay) -->
    <div
      id="stock-modal"
      class="modal-overlay"
      style="display: none;"
      role="dialog"
      aria-modal="true"
      aria-labelledby="stock-modal-title"
    >
      <div class="modal-content glass-panel animate-scale-up">
        <div class="modal-header">
          <h3 id="stock-modal-title">Add Beer</h3>
          <button id="close-stock-modal" class="btn-icon" type="button" aria-label="Close stock editor modal">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <form id="stock-form" class="edit-form">
          <input type="hidden" id="stock-id" />
          <div class="input-group">
            <label for="stock-name" class="input-label">Name</label>
            <input id="stock-name" type="text" class="input-field" required />
          </div>
          <div class="input-group">
            <label for="stock-brewery" class="input-label">Brewery</label>
            <input id="stock-brewery" type="text" class="input-field" required />
          </div>
          <div class="input-group">
            <label for="stock-style" class="input-label">Style</label>
            <input id="stock-style" type="text" class="input-field" required />
          </div>
          <div class="input-group">
            <label for="stock-year" class="input-label">Year (optional)</label>
            <input id="stock-year" type="text" class="input-field" placeholder="N/A" />
          </div>
          <div class="checkbox-group">
            <input type="checkbox" id="stock-unavailable" class="checkbox-input" />
            <label for="stock-unavailable" class="checkbox-label">Currently unavailable</label>
          </div>
          <div class="modal-actions">
            <button type="button" id="delete-stock-btn" class="btn-danger-outline btn-sm" style="display: none;">Delete</button>
            <div class="flex-grow"></div>
            <button type="submit" class="btn-primary btn-sm" id="stock-save-btn">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  import { escapeHtml } from '../lib/escapeHtml';

  type BeerStockRow = {
    id: string;
    name: string;
    brewery: string;
    style: string;
    year: string | null;
    is_unavailable: boolean;
  };

  let allStock: BeerStockRow[] = [];

  const logoutBtn = document.getElementById('logout-btn');
  const openStockOverlayBtn = document.getElementById('open-stock-overlay-btn');
  const stockOverlay = document.getElementById('stock-overlay') as HTMLElement | null;
  const closeStockOverlayBtn = document.getElementById('close-stock-overlay') as HTMLButtonElement | null;
  const tabsContainer = document.getElementById('tabs-container');
  const statUnpaid = document.getElementById('stat-unpaid');
  const statToday = document.getElementById('stat-today');
  const statTodayLabel = document.getElementById('stat-today-label');
  const statCustomers = document.getElementById('stat-customers');

  const dayNavigatorEl = document.getElementById('day-navigator');
  const dayLabelEl = document.getElementById('day-label');
  const daySelectEl = document.getElementById('day-select') as HTMLSelectElement | null;
  const dayPrevBtn = document.getElementById('day-prev') as HTMLButtonElement | null;
  const dayNextBtn = document.getElementById('day-next') as HTMLButtonElement | null;

  let availableDays: string[] = [];
  let selectedDayKey: string = '';

  const catalogSearchInput = document.getElementById('catalog-search') as HTMLInputElement | null;
  const catalogStatusEl = document.getElementById('catalog-status');
  const catalogTableWrapEl = document.getElementById('catalog-table-wrap') as HTMLElement | null;
  const catalogTableBodyEl = document.getElementById('catalog-table-body') as HTMLElement | null;
  const addBeerStockBtn = document.getElementById('add-beer-stock-btn') as HTMLButtonElement | null;
  const stockModalEl = document.getElementById('stock-modal') as HTMLElement | null;
  const stockFormEl = document.getElementById('stock-form') as HTMLFormElement | null;
  const stockIdInput = document.getElementById('stock-id') as HTMLInputElement | null;
  const stockNameInput = document.getElementById('stock-name') as HTMLInputElement | null;
  const stockBreweryInput = document.getElementById('stock-brewery') as HTMLInputElement | null;
  const stockStyleInput = document.getElementById('stock-style') as HTMLInputElement | null;
  const stockYearInput = document.getElementById('stock-year') as HTMLInputElement | null;
  const stockUnavailableInput = document.getElementById('stock-unavailable') as HTMLInputElement | null;
  const stockModalTitleEl = document.getElementById('stock-modal-title') as HTMLElement | null;
  const closeStockModalBtn = document.getElementById('close-stock-modal') as HTMLButtonElement | null;
  const deleteStockBtn = document.getElementById('delete-stock-btn') as HTMLButtonElement | null;
  const stockSaveBtn = document.getElementById('stock-save-btn') as HTMLButtonElement | null;

  async function init() {
    console.log('[Manager] init() called');
    const { data: { session } } = await supabase.auth.getSession();
    console.log('[Manager] Session found:', !!session);
    if (!session) { window.location.href = '/login'; return; }

    console.log('[Manager] Fetching profile...');
    const { data: profile } = await supabase
      .from('profiles').select('role').eq('id', session.user.id).single();
    console.log('[Manager] Profile role:', profile?.role);

    if (profile?.role !== 'manager') { 
      console.warn('[Manager] Access denied: not a manager');
      window.location.href = '/customer'; 
      return; 
    }

    console.log('[Manager] Loading dashboard data...');
    try {
      await loadDashboard();
      console.log('[Manager] Dashboard loaded');
    } catch (err) {
      console.error('[Manager] Dashboard load failed:', err);
    }

    // Day navigation (filters dashboard by beers' created_at date)
    dayPrevBtn?.addEventListener('click', () => {
      const idx = availableDays.indexOf(selectedDayKey);
      if (idx < availableDays.length - 1) {
        selectedDayKey = availableDays[idx + 1];
        updateDayUI();
        void loadDashboard();
      }
    });

    dayNextBtn?.addEventListener('click', () => {
      const idx = availableDays.indexOf(selectedDayKey);
      if (idx > 0) {
        selectedDayKey = availableDays[idx - 1];
        updateDayUI();
        void loadDashboard();
      }
    });

    daySelectEl?.addEventListener('change', () => {
      const val = daySelectEl.value;
      if (val && availableDays.includes(val)) {
        selectedDayKey = val;
        updateDayUI();
        void loadDashboard();
      }
    });

    wireStockEvents();

    // Realtime: refresh manager dashboard on any beer change
    console.log('[Realtime] Setting up manager subscription...');
    supabase
      .channel('manager-beers')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'beers' }, (payload) => {
        console.log('[Realtime] MANAGER RECEIVED CHANGE:', payload);
        loadDashboard();
      })
      .subscribe((status, err) => {
        console.log('[Realtime] Manager subscription status:', status);
        if (err) console.error('[Realtime] Manager subscription error:', err);
      });
  }

  function getDateKey(d: Date): string {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  function getTodayKey(): string {
    return getDateKey(new Date());
  }

  function formatDayLabel(key: string): string {
    const today = getTodayKey();
    if (key === today) return 'Today';
    const d = new Date(key + 'T12:00:00');
    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    if (getDateKey(yesterday) === key) return 'Yesterday';
    return d.toLocaleDateString([], { weekday: 'short', month: 'short', day: 'numeric' });
  }

  function updateDayUI() {
    if (dayLabelEl && selectedDayKey) dayLabelEl.textContent = formatDayLabel(selectedDayKey);

    if (daySelectEl) {
      daySelectEl.innerHTML = availableDays
        .map(
          (k) =>
            `<option value="${escapeHtml(k)}"${k === selectedDayKey ? ' selected' : ''}>${escapeHtml(
              formatDayLabel(k),
            )}</option>`,
        )
        .join('');
      daySelectEl.value = selectedDayKey;
    }

    if (dayPrevBtn) {
      const idx = availableDays.indexOf(selectedDayKey);
      dayPrevBtn.setAttribute('aria-disabled', idx >= availableDays.length - 1 ? 'true' : 'false');
      dayPrevBtn.disabled = idx >= availableDays.length - 1;
    }

    if (dayNextBtn) {
      const idx = availableDays.indexOf(selectedDayKey);
      dayNextBtn.setAttribute('aria-disabled', idx <= 0 ? 'true' : 'false');
      dayNextBtn.disabled = idx <= 0;
    }
  }

  function getDayBoundsISO(dayKey: string): { startISO: string; endISO: string } {
    const [yearStr, monthStr, dayStr] = dayKey.split('-');
    const year = Number(yearStr);
    const monthIndex = Number(monthStr) - 1; // local timezone month index
    const day = Number(dayStr);
    const startLocal = new Date(year, monthIndex, day, 0, 0, 0, 0);
    const endLocal = new Date(year, monthIndex, day + 1, 0, 0, 0, 0);
    return { startISO: startLocal.toISOString(), endISO: endLocal.toISOString() };
  }

  async function loadDashboard() {
    const { data: profiles } = await supabase
      .from('profiles').select('id, email, role, full_name').eq('role', 'customer');
    const { data: beers } = await supabase
      .from('beers').select('*').order('created_at', { ascending: false });

    if (!tabsContainer) return;

    const allBeers = beers || [];
    const allProfiles = profiles || [];

    // Build available days from beer.created_at (same local day logic as customer page)
    const daySet = new Set<string>();
    allBeers.forEach(b => daySet.add(getDateKey(new Date(b.created_at))));
    daySet.add(getTodayKey());
    availableDays = Array.from(daySet).sort().reverse();

    if (!selectedDayKey || !availableDays.includes(selectedDayKey)) {
      const todayKey = getTodayKey();
      selectedDayKey = availableDays.includes(todayKey) ? todayKey : (availableDays[0] ?? '');
    }

    const dayBeers = selectedDayKey
      ? allBeers.filter(b => getDateKey(new Date(b.created_at)) === selectedDayKey)
      : [];

    if (dayNavigatorEl) dayNavigatorEl.hidden = availableDays.length === 0;
    updateDayUI();

    const unpaidCount = dayBeers.filter(b => !b.is_paid).length;
    const dayCount = dayBeers.length;
    const activeCustomers = allProfiles.filter(p => dayBeers.some(b => b.user_id === p.id)).length;

    if (statUnpaid) statUnpaid.textContent = unpaidCount.toString();
    if (statToday) statToday.textContent = dayCount.toString();
    if (statTodayLabel) statTodayLabel.textContent = `${formatDayLabel(selectedDayKey)}'s Drinks`;
    if (statCustomers) statCustomers.textContent = activeCustomers.toString();

    const customersWithBeers = allProfiles.filter(p => dayBeers.some(b => b.user_id === p.id));

    if (customersWithBeers.length === 0) {
      tabsContainer.innerHTML = '<div class="glass-panel text-center" style="padding: 2rem; color: var(--text-secondary);">No drink history yet.</div>';
      return;
    }

    let html = '';

    customersWithBeers.forEach(profile => {
      const userBeers = dayBeers.filter(b => b.user_id === profile.id);
      
      // Group by name + paid status
      type GroupData = { name: string; notes: string; items: any[]; is_paid: boolean; };
      const groups: Record<string, GroupData> = {};
      userBeers.forEach(b => {
        const key = `${b.name.toLowerCase()}::${b.is_paid}`;
        if (groups[key]) {
          groups[key].items.push(b);
        } else {
          groups[key] = { name: b.name, notes: b.notes || '', items: [b], is_paid: b.is_paid };
        }
      });

      const groupList = Object.values(groups).sort((a, b) => (a.is_paid === b.is_paid ? 0 : a.is_paid ? 1 : -1));
      const unpaidGroups = groupList.filter(g => !g.is_paid);
      const paidGroups = groupList.filter(g => g.is_paid);
      const unpaidTotal = unpaidGroups.reduce((s, g) => s + g.items.length, 0);
      const paidTotal = paidGroups.reduce((s, g) => s + g.items.length, 0);
      const hasUnpaid = unpaidTotal > 0;

      const renderGroup = (g: GroupData, groupIndex: number, sectionType: string) => {
        const groupId = `group-${profile.id.substring(0,4)}-${sectionType}-${groupIndex}`;
        return `
        <div class="beer-group-container" id="${groupId}">
          <div class="beer-mini-row ${g.is_paid ? 'is-paid' : 'is-unpaid'} group-header" data-toggle-group="${groupId}">
            <div class="beer-mini-left">
              <span class="beer-mini-name">${g.name}</span>
              ${g.notes ? `<span class="beer-mini-notes">${g.notes}</span>` : ''}
              <span class="expand-hint">Click to manage individual items</span>
            </div>
            <span class="beer-mini-count ${g.is_paid ? 'count-paid' : 'count-unpaid'}">×${g.items.length}</span>
          </div>
          <div class="beer-group-items" style="display: none;">
            ${g.items.map(item => `
              <div class="individual-beer-row" data-id="${item.id}">
                <div class="item-meta">
                  <span class="item-time">${new Date(item.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                  <span class="item-date">${new Date(item.created_at).toLocaleDateString([], { month: 'short', day: 'numeric' })}</span>
                </div>
                <div class="item-actions">
                  <button class="btn-icon btn-edit" 
                          data-id="${item.id}" 
                          data-name="${item.name.replace(/"/g, '&quot;')}" 
                          data-notes="${(item.notes || '').replace(/"/g, '&quot;')}" 
                          data-paid="${item.is_paid}"
                          title="Edit drink" aria-label="Edit drink">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                  </button>
                  <button
                    class="btn-toggle-status ${item.is_paid ? 'btn-unpay' : 'btn-pay'}"
                    data-id="${item.id}"
                    data-current="${item.is_paid}"
                    title="${item.is_paid ? 'Mark Unpaid' : 'Mark Paid'}"
                    aria-label="${item.is_paid ? 'Mark Unpaid' : 'Mark Paid'}"
                  >
                    ${item.is_paid 
                      ? `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>`
                      : `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`
                    }
                  </button>
                </div>
              </div>
            `).join('')}
          </div>
        </div>`;
      };

      html += `
        <div class="glass-panel user-tab-card ${!hasUnpaid ? 'all-settled' : ''}">
          <div class="user-tab-header">
            <div class="user-tab-info">
              <h4>${profile.full_name || profile.email}</h4>
              ${profile.full_name ? `<span class="user-email-sub">${profile.email}</span>` : ''}
              <div class="tab-pills">
                ${unpaidTotal > 0 ? `<span class="tab-pill pill-unpaid">${unpaidTotal} unpaid</span>` : ''}
                ${paidTotal > 0 ? `<span class="tab-pill pill-paid">${paidTotal} paid</span>` : ''}
                <span class="tab-pill pill-total">${unpaidTotal + paidTotal} total</span>
              </div>
            </div>
            ${hasUnpaid
              ? `<button class="btn-primary btn-sm mark-paid-btn" data-userid="${profile.id}">Mark All Paid</button>`
              : `<span class="badge badge-success">✓ Settled</span>`
            }
          </div>
          <div class="user-tab-body">
            ${unpaidGroups.length > 0 ? `
              <div class="beer-section">
                <div class="beer-section-label unpaid-label">On Tab</div>
                ${unpaidGroups.map((g, i) => renderGroup(g, i, 'unpaid')).join('')}
              </div>` : ''}
            ${paidGroups.length > 0 ? `
              <div class="beer-section ${unpaidGroups.length > 0 ? 'section-divider' : ''}">
                <div class="beer-section-label paid-label">Paid</div>
                ${paidGroups.map((g, i) => renderGroup(g, i, 'paid')).join('')}
              </div>` : ''}
          </div>
        </div>`;
    });

    tabsContainer.innerHTML = html;

    // Expand/Collapse Group Logic
    document.querySelectorAll('.group-header').forEach(header => {
      header.setAttribute('role', 'button');
      header.setAttribute('tabindex', '0');
      header.setAttribute('aria-expanded', 'false');

      header.addEventListener('click', () => {
        const groupId = header.getAttribute('data-toggle-group');
        if (!groupId) return;
        const groupContainer = document.getElementById(groupId);
        const itemsList = groupContainer?.querySelector('.beer-group-items') as HTMLElement;
        if (itemsList) {
          const isHidden = itemsList.style.display === 'none';
          itemsList.style.display = isHidden ? 'flex' : 'none';
          header.classList.toggle('is-expanded', isHidden);
          header.setAttribute('aria-expanded', String(isHidden));
        }
      });

      header.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        if (key !== 'Enter' && key !== ' ') return;
        e.preventDefault();
        (header as HTMLElement).click();
      });
    });

    // Mark All Paid
    document.querySelectorAll('.mark-paid-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const userId = (e.target as HTMLElement).getAttribute('data-userid') ?? '';
        if (!userId) return;
        const el = e.target as HTMLButtonElement;
        el.textContent = 'Processing…';
        el.disabled = true;
        try {
          const { startISO, endISO } = getDayBoundsISO(selectedDayKey);
          const { error } = await supabase
            .from('beers')
            .update({ is_paid: true })
            .eq('user_id', userId)
            .eq('is_paid', false)
            .gte('created_at', startISO)
            .lt('created_at', endISO);
          if (error) throw error;
          await loadDashboard();
        } catch (err) {
          alert('Error updating database');
          el.textContent = 'Mark All Paid';
          el.disabled = false;
        }
      });
    });

    // Individual Toggle Status
    document.querySelectorAll('.btn-toggle-status').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).getAttribute('data-id') ?? '';
        const currentStatus = (btn as HTMLElement).getAttribute('data-current') === 'true';
        
        try {
          const { error } = await supabase.from('beers').update({ is_paid: !currentStatus }).eq('id', id);
          if (error) throw error;
          await loadDashboard();
        } catch (err) {
          alert('Error toggling status');
        }
      });
    });

    // Edit Modal Logic
    const editModal = document.getElementById('edit-modal') as HTMLElement;
    const editForm = document.getElementById('edit-beer-form') as HTMLFormElement;
    const editIdInput = document.getElementById('edit-beer-id') as HTMLInputElement;
    const editNameInput = document.getElementById('edit-beer-name') as HTMLInputElement;
    const editNotesInput = document.getElementById('edit-beer-notes') as HTMLTextAreaElement;
    const editPaidInput = document.getElementById('edit-beer-paid') as HTMLInputElement;
    const closeModal = document.getElementById('close-modal');
    const deleteBtn = document.getElementById('delete-beer-btn');
    document.querySelectorAll('.btn-edit').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).getAttribute('data-id') ?? '';
        const name = (btn as HTMLElement).getAttribute('data-name') ?? '';
        const notes = (btn as HTMLElement).getAttribute('data-notes') ?? '';
        const isPaid = (btn as HTMLElement).getAttribute('data-paid') === 'true';
        
        editIdInput.value = id;
        editNameInput.value = name;
        editNotesInput.value = notes;
        editPaidInput.checked = isPaid;
        editModal.style.display = 'flex';
      });
    });

    closeModal?.addEventListener('click', () => editModal.style.display = 'none');
    
    editForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = editIdInput.value;
      const name = editNameInput.value;
      const notes = editNotesInput.value;
      const is_paid = editPaidInput.checked;
      
      try {
        const { error } = await supabase.from('beers').update({ name, notes, is_paid }).eq('id', id);
        if (error) throw error;
        editModal.style.display = 'none';
        await loadDashboard();
      } catch (err) {
        alert('Error saving changes');
      }
    });

    deleteBtn?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete this drink?')) return;
      const id = editIdInput.value;
      try {
        const { error } = await supabase.from('beers').delete().eq('id', id);
        if (error) throw error;
        editModal.style.display = 'none';
        await loadDashboard();
      } catch (err) {
        alert('Error deleting drink');
      }
    });
  }

  async function loadStock() {
    if (catalogStatusEl) catalogStatusEl.textContent = 'Loading catalog…';
    if (catalogTableWrapEl) catalogTableWrapEl.hidden = true;

    const { data, error } = await supabase
      .from('beer_stock')
      .select('id, name, brewery, style, year, is_unavailable')
      .order('name', { ascending: true });

    if (error) {
      if (catalogStatusEl) catalogStatusEl.textContent = 'Failed to load catalog.';
      console.error('[Manager] Failed to load beer_stock:', error);
      return;
    }

    allStock = (data ?? []) as BeerStockRow[];
    renderStockTable();
  }

  function renderStockTable() {
    if (!catalogTableBodyEl || !catalogStatusEl || !catalogTableWrapEl) return;

    const query = (catalogSearchInput?.value ?? '').trim().toLowerCase();
    const filtered = allStock.filter((row) => {
      if (!query) return true;
      const haystack = `${row.name} ${row.brewery} ${row.style}`.toLowerCase();
      return haystack.includes(query);
    });

    if (filtered.length === 0) {
      catalogStatusEl.textContent = query ? 'No beers match your search.' : 'No beers in catalog yet.';
      catalogTableWrapEl.hidden = true;
      return;
    }

    catalogStatusEl.textContent = '';
    catalogTableWrapEl.hidden = false;

    catalogTableBodyEl.innerHTML = filtered.map((row, index) => {
      const safeName = row.name ?? '';
      const safeBrewery = row.brewery ?? '';
      const safeStyle = row.style ?? '';
      const safeYear = row.year ?? 'N/A';
      const isEven = index % 2 === 0;
      const rowBg = isEven ? 'rgba(255, 255, 255, 0.06)' : 'rgba(30, 41, 59, 0.8)';
      return `
        <tr class="catalog-table-row" data-id="${row.id}" style="background-color: ${rowBg};">
          <td>${safeName}</td>
          <td>${safeBrewery}</td>
          <td>${safeStyle}</td>
          <td>${safeYear}</td>
          <td>
            <span class="badge ${row.is_unavailable ? 'badge-warning' : 'badge-success'}">
              ${row.is_unavailable ? 'Unavailable' : 'Available'}
            </span>
          </td>
          <td class="table-actions">
            <button type="button" class="btn-icon btn-edit-stock" data-id="${row.id}" title="Edit" aria-label="Edit catalog beer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            </button>
          </td>
        </tr>
      `;
    }).join('');
  }

  function openStockModalForCreate() {
    if (!stockModalEl || !stockFormEl || !stockModalTitleEl || !deleteStockBtn) return;
    stockFormEl.reset();
    if (stockIdInput) stockIdInput.value = '';
    if (stockUnavailableInput) stockUnavailableInput.checked = false;
    stockModalTitleEl.textContent = 'Add Beer';
    deleteStockBtn.style.display = 'none';
    stockModalEl.style.display = 'flex';
  }

  function openStockModalForEdit(row: BeerStockRow) {
    if (!stockModalEl || !stockFormEl || !stockModalTitleEl || !deleteStockBtn) return;
    if (stockIdInput) stockIdInput.value = row.id;
    if (stockNameInput) stockNameInput.value = row.name ?? '';
    if (stockBreweryInput) stockBreweryInput.value = row.brewery ?? '';
    if (stockStyleInput) stockStyleInput.value = row.style ?? '';
    if (stockYearInput) stockYearInput.value = row.year ?? '';
    if (stockUnavailableInput) stockUnavailableInput.checked = !!row.is_unavailable;
    stockModalTitleEl.textContent = 'Edit Beer';
    deleteStockBtn.style.display = 'inline-flex';
    stockModalEl.style.display = 'flex';
  }

  function closeStockModal() {
    if (stockModalEl) stockModalEl.style.display = 'none';
  }

  function wireStockEvents() {
    catalogSearchInput?.addEventListener('input', () => renderStockTable());

    addBeerStockBtn?.addEventListener('click', () => openStockModalForCreate());

    closeStockModalBtn?.addEventListener('click', () => closeStockModal());

    stockFormEl?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!stockNameInput || !stockBreweryInput || !stockStyleInput || !stockUnavailableInput || !stockSaveBtn) return;
      const id = stockIdInput?.value ?? '';
      const payload = {
        name: stockNameInput.value.trim(),
        brewery: stockBreweryInput.value.trim(),
        style: stockStyleInput.value.trim(),
        year: (stockYearInput?.value ?? '').trim() || null,
        is_unavailable: stockUnavailableInput.checked,
      };
      if (!payload.name || !payload.brewery || !payload.style) return;
      const originalText = stockSaveBtn.textContent ?? 'Save';
      stockSaveBtn.textContent = 'Saving…';
      stockSaveBtn.disabled = true;
      stockSaveBtn.setAttribute('aria-busy', 'true');
      try {
        if (id) {
          const { error } = await supabase.from('beer_stock').update(payload).eq('id', id);
          if (error) throw error;
        } else {
          const { error } = await supabase.from('beer_stock').insert(payload);
          if (error) throw error;
        }
        closeStockModal();
        await loadStock();
      } catch (err) {
        alert('Error saving beer. Please try again.');
        console.error('[Manager] Save error:', err);
      } finally {
        stockSaveBtn.textContent = originalText;
        stockSaveBtn.disabled = false;
        stockSaveBtn.removeAttribute('aria-busy');
      }
    });

    deleteStockBtn?.addEventListener('click', async () => {
      if (!stockIdInput) return;
      const id = stockIdInput.value;
      if (!id || !confirm('Delete this beer from the catalog?')) return;
      try {
        const { error } = await supabase.from('beer_stock').delete().eq('id', id);
        if (error) throw error;
        closeStockModal();
        await loadStock();
      } catch (err) {
        alert('Error deleting beer. Please try again.');
        console.error('[Manager] Delete error:', err);
      }
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('.btn-edit-stock')) {
        const btn = target.closest('.btn-edit-stock');
        const id = btn?.getAttribute('data-id');
        if (!id) return;
        const row = allStock.find((r) => r.id === id);
        if (row) openStockModalForEdit(row);
      }
    });
  }

  // Open/close beer stock overlay
  openStockOverlayBtn?.addEventListener('click', async () => {
    if (stockOverlay) {
      stockOverlay.style.display = 'flex';
      document.body.classList.add('no-scroll');
      await loadStock();
    }
  });

  function hideStockOverlay() {
    if (stockOverlay) {
      stockOverlay.style.display = 'none';
    }
    document.body.classList.remove('no-scroll');
  }

  closeStockOverlayBtn?.addEventListener('click', () => {
    hideStockOverlay();
  });

  stockOverlay?.addEventListener('click', (e) => {
    if (e.target === stockOverlay) {
      hideStockOverlay();
    }
  });

  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  init();
</script>

