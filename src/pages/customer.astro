---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Tab">
  <div class="container user-dashboard">
    <header class="dashboard-header animate-fade-in">
      <div class="header-left">
        <h2 id="user-display-name">My Tab</h2>
        <div class="user-meta-sub">
          <p class="user-email" id="user-email">Loading...</p>
          <button id="edit-profile-btn" class="btn-text-link">Edit Name</button>
        </div>
      </div>
      <button id="logout-btn" class="btn-secondary btn-sm">Sign Out</button>
    </header>

    <!-- Profile Modal -->
    <div id="profile-modal" class="modal-overlay" style="display: none;">
      <div class="modal-content glass-panel animate-scale-up">
        <div class="modal-header">
          <h3>My Profile</h3>
          <button id="close-profile-modal" class="btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <form id="profile-form" class="edit-form">
          <div class="input-group">
            <label for="profile-name" class="input-label">Your Name</label>
            <input type="text" id="profile-name" class="input-field" placeholder="How should we call you?" required>
          </div>
          <div class="modal-actions">
            <div class="flex-grow"></div>
            <button type="submit" class="btn-primary btn-sm">Save Profile</button>
          </div>
        </form>
      </div>
    </div>

    <div class="actions-panel glass-panel animate-fade-in" style="animation-delay: 0.1s;">
      <h3>Add a Drink</h3>
      <form id="add-beer-form" class="add-beer-form">
        <div class="input-group">
          <label for="beer-name" class="input-label">What are you drinking?</label>
          <input type="text" id="beer-name" class="input-field" placeholder="e.g. IPA, Stout, Local Craft..." required>
        </div>
        
        <div class="input-group">
          <label for="beer-notes" class="input-label">Notes (optional)</label>
          <textarea id="beer-notes" class="input-field" placeholder="How is it?"></textarea>
        </div>

        <button type="submit" id="submit-beer" class="btn-primary w-full">
          Add to Tab
        </button>
      </form>
    </div>

    <div class="history-panel animate-fade-in" style="animation-delay: 0.2s;">
      <h3>Recent History</h3>
      <div id="beer-list" class="beer-list">
        <div class="loading-state">Loading your drinks...</div>
      </div>
    </div>

    <!-- Profile Modal (Existing) -->
    <!-- ... stays as is ... -->

    <!-- Beer Edit Modal -->
    <div id="beer-edit-modal" class="modal-overlay" style="display: none;">
      <div class="modal-content glass-panel animate-scale-up">
        <div class="modal-header">
          <h3>Edit Drink</h3>
          <button id="close-beer-modal" class="btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <form id="beer-edit-form" class="edit-form">
          <input type="hidden" id="edit-beer-id">
          <div class="input-group">
            <label for="edit-beer-name" class="input-label">Drink Name</label>
            <input type="text" id="edit-beer-name" class="input-field" readonly style="opacity: 0.6; cursor: not-allowed;">
          </div>
          <div class="input-group">
            <label for="edit-beer-notes" class="input-label">Notes</label>
            <textarea id="edit-beer-notes" class="input-field" rows="3"></textarea>
          </div>
          <div class="checkbox-group">
            <input type="checkbox" id="edit-beer-paid" class="checkbox-input">
            <label for="edit-beer-paid" class="checkbox-label">Mark as Paid</label>
          </div>
          <div class="modal-actions">
            <button type="button" id="delete-beer-btn" class="btn-danger-outline btn-sm">Delete</button>
            <div class="flex-grow"></div>
            <button type="submit" class="btn-primary btn-sm">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  let currentUser: any = null;

  const userEmailEl = document.getElementById('user-email');
  const userDisplayNameEl = document.getElementById('user-display-name');
  const logoutBtn = document.getElementById('logout-btn');
  const addBeerForm = document.getElementById('add-beer-form') as HTMLFormElement;
  const beerListEl = document.getElementById('beer-list');
  const editProfileBtn = document.getElementById('edit-profile-btn');
  const profileModal = document.getElementById('profile-modal') as HTMLElement;
  const profileForm = document.getElementById('profile-form') as HTMLFormElement;
  const profileNameInput = document.getElementById('profile-name') as HTMLInputElement;
  const closeProfileModal = document.getElementById('close-profile-modal');

  // Load User & Data
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    
    if (!session) {
      window.location.href = '/login';
      return;
    }

    currentUser = session.user;
    if (userEmailEl) userEmailEl.textContent = currentUser.email;

    // Check role, if manager redirect to manager page
    let { data: profile, error: profileError } = await supabase
      .from('profiles')
      .select('role, full_name')
      .eq('id', currentUser.id)
      .maybeSingle();

    // FALLBACK: If profile is missing (OAuth delay or trigger fail), create it now
    if (!profile && !profileError) {
      console.log('[Auth] Profile missing, attempting fallback creation...');
      const fallbackName = currentUser.user_metadata?.full_name || currentUser.user_metadata?.name || '';
      
      const { data: newProfile, error: createError } = await supabase
        .from('profiles')
        .insert({
          id: currentUser.id,
          email: currentUser.email,
          full_name: fallbackName,
          role: 'customer'
        })
        .select()
        .single();
      
      if (createError) {
        console.error('[Auth] Fallback profile creation failed:', createError);
      } else {
        console.log('[Auth] Fallback profile created successfully');
        profile = newProfile;
      }
    }

    if (profile?.full_name && userDisplayNameEl) {
      userDisplayNameEl.textContent = profile.full_name;
    }

    if (profile?.role === 'manager') {
      window.location.href = '/manager';
      return;
    }

    loadBeers();

    // Subscribe to real-time changes for this user's beers
    console.log('[Realtime] Setting up subscription for user:', currentUser.id);
    
    supabase
      .channel('customer-beers-' + currentUser.id)
      .on(
        'postgres_changes',
        { 
          event: '*', 
          schema: 'public', 
          table: 'beers' 
          // filter: `user_id=eq.${currentUser.id}` // TEMPORARILY DISABLED FILTER TO DEBUG
        },
        (payload) => {
          console.log('[Realtime] Beer change payload received:', payload);
          // Only reload if the change belongs to the current user
          const record = (payload.new as any)?.user_id ? payload.new as any : payload.old as any;
          if (record && record.user_id === currentUser?.id) {
            console.log('[Realtime] Data matches current user. Reloading...');
            loadBeers();
          }
        }
      )
      .subscribe((status, err) => {
        console.log('[Realtime] Subscription status:', status);
        if (err) console.error('[Realtime] Subscription error:', err);
      });

    // Beer Edit Modal Elements
    const beerModal = document.getElementById('beer-edit-modal') as HTMLElement;
    const beerForm = document.getElementById('beer-edit-form') as HTMLFormElement;
    const beerIdInput = document.getElementById('edit-beer-id') as HTMLInputElement;
    const beerNameInput = document.getElementById('edit-beer-name') as HTMLInputElement;
    const beerNotesInput = document.getElementById('edit-beer-notes') as HTMLTextAreaElement;
    const beerPaidInput = document.getElementById('edit-beer-paid') as HTMLInputElement;
    const closeBeerModal = document.getElementById('close-beer-modal');
    const deleteBeerBtn = document.getElementById('delete-beer-btn');

    // Handle Beer Edit Logic (Delegated)
    beerListEl?.addEventListener('click', (e) => {
      const editBtn = (e.target as Element).closest('.btn-edit-beer');
      if (!editBtn) return;

      const id = editBtn.getAttribute('data-id') ?? '';
      const name = editBtn.getAttribute('data-name') ?? '';
      const notes = editBtn.getAttribute('data-notes') ?? '';
      const isPaid = editBtn.getAttribute('data-paid') === 'true';

      beerIdInput.value = id;
      beerNameInput.value = name;
      beerNotesInput.value = notes;
      beerPaidInput.checked = isPaid;
      beerModal.style.display = 'flex';
    });

    closeBeerModal?.addEventListener('click', () => {
      beerModal.style.display = 'none';
    });

    beerForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = beerIdInput.value;
      const notes = beerNotesInput.value;
      const is_paid = beerPaidInput.checked;

      try {
        const { error } = await supabase
          .from('beers')
          .update({ notes, is_paid })
          .eq('id', id);

        if (error) throw error;
        beerModal.style.display = 'none';
        loadBeers();
      } catch (err) {
        alert('Error updating drink');
      }
    });

    deleteBeerBtn?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete this drink?')) return;
      const id = beerIdInput.value;
      try {
        const { error } = await supabase.from('beers').delete().eq('id', id);
        if (error) throw error;
        beerModal.style.display = 'none';
        loadBeers();
      } catch (err) {
        alert('Error deleting drink');
      }
    });

    // Profile Modal Logic
    editProfileBtn?.addEventListener('click', () => {
      if (userDisplayNameEl?.textContent && userDisplayNameEl.textContent !== 'My Tab') {
        profileNameInput.value = userDisplayNameEl.textContent;
      }
      profileModal.style.display = 'flex';
    });

    closeProfileModal?.addEventListener('click', () => {
      profileModal.style.display = 'none';
    });

    profileForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const newName = profileNameInput.value.trim();
      if (!newName) return;

      const { error } = await supabase
        .from('profiles')
        .update({ full_name: newName })
        .eq('id', currentUser.id);

      if (error) {
        alert('Error updating profile');
      } else {
        if (userDisplayNameEl) userDisplayNameEl.textContent = newName;
        profileModal.style.display = 'none';
      }
    });
  }

  async function loadBeers() {
    if (!beerListEl || !currentUser) return;

    const { data, error } = await supabase
      .from('beers')
      .select('*')
      .eq('user_id', currentUser.id)
      .order('created_at', { ascending: false });

    if (error) {
      beerListEl.innerHTML = `<div class="error-state">Failed to load drinks</div>`;
      return;
    }

    // Group by name + paid status
    type GroupData = { name: string; notes: string; items: any[]; is_paid: boolean; };
    const groups: Record<string, GroupData> = {};
    data.forEach(b => {
      const key = `${b.name.toLowerCase()}::${b.is_paid}`;
      if (groups[key]) {
        groups[key].items.push(b);
      } else {
        groups[key] = { name: b.name, notes: b.notes || '', items: [b], is_paid: b.is_paid };
      }
    });

    const groupList = Object.values(groups).sort((a, b) => a.is_paid ? 1 : -1);
    const unpaidGroups = groupList.filter(g => !g.is_paid);
    const paidGroups = groupList.filter(g => g.is_paid);

    const renderGroup = (g: GroupData, groupIndex: number, sectionType: string) => {
      const groupId = `group-customer-${sectionType}-${groupIndex}`;
      return `
      <div class="beer-group-container" id="${groupId}">
        <div class="beer-item glass-panel ${g.is_paid ? 'paid' : 'unpaid'} group-header" data-toggle-group="${groupId}">
          <div class="beer-content">
            <div class="beer-info">
              <div class="beer-title-row">
                <h4>${g.name}</h4>
                <div class="header-status">
                  ${g.is_paid 
                    ? `<span class="badge badge-success">Paid</span>` 
                    : `<span class="badge badge-warning">On Tab</span>`
                  }
                  <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </div>
              </div>
              <div class="group-meta">
                <span class="beer-qty">×${g.items.length}</span>
                <span class="expand-hint">${g.notes || 'Click to see details'}</span>
              </div>
            </div>
          </div>
        </div>
        <div class="beer-group-items" style="display: none;">
          ${g.items.map(item => {
            const safeName = (item.name || 'Drink').replace(/"/g, '&quot;');
            const safeNotes = (item.notes || '').replace(/"/g, '&quot;');
            const dateStr = new Date(item.created_at).toLocaleDateString([], { month: 'short', day: 'numeric' })
              + ' ' + new Date(item.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            return `
            <div class="individual-beer-row glass-panel" data-id="${item.id}">
              <div class="item-meta">
                <span class="item-time">${dateStr}</span>
              </div>
              <div class="item-actions">
                <button type="button" class="btn-icon btn-edit-beer" 
                        data-id="${item.id}" 
                        data-name="${safeName}" 
                        data-notes="${safeNotes}" 
                        data-paid="${item.is_paid}"
                        title="Edit drink">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                </button>
                <button type="button" class="btn-icon btn-repeat" data-name="${safeName}" data-notes="${safeNotes}" title="Add another">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </button>
              </div>
            </div>`;
          }).join('')}
        </div>
      </div>`;
    };

    beerListEl.innerHTML = `
      ${unpaidGroups.length > 0 ? `
        <div class="beer-section">
          <div class="beer-section-label unpaid-label">On Tab</div>
          ${unpaidGroups.map((g, i) => renderGroup(g, i, 'unpaid')).join('')}
        </div>` : ''}
      ${paidGroups.length > 0 ? `
        <div class="beer-section ${unpaidGroups.length > 0 ? 'section-divider' : ''}">
          <div class="beer-section-label paid-label">Paid</div>
          ${paidGroups.map((g, i) => renderGroup(g, i, 'paid')).join('')}
        </div>` : ''}
      ${data.length === 0 ? `
        <div class="empty-state glass-panel text-center">
          <p>Your tab is empty! Time to grab a drink.</p>
        </div>` : ''}
    `;

    // Add Expand/Collapse Event Listeners
    beerListEl.querySelectorAll('.group-header').forEach(header => {
      header.addEventListener('click', (e) => {
        // Don't toggle if clicking an action button (though we don't have many here)
        if ((e.target as HTMLElement).closest('.btn-icon')) return;
        
        const groupId = header.getAttribute('data-toggle-group');
        if (!groupId) return;
        const groupContainer = document.getElementById(groupId);
        const itemsList = groupContainer?.querySelector('.beer-group-items') as HTMLElement;
        if (itemsList) {
          const isHidden = itemsList.style.display === 'none';
          itemsList.style.display = isHidden ? 'flex' : 'none';
          header.classList.toggle('is-expanded', isHidden);
        }
      });
    });
  }

  // Handle Add Drink
  addBeerForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameInput = document.getElementById('beer-name') as HTMLInputElement;
    const notesInput = document.getElementById('beer-notes') as HTMLTextAreaElement;
    const submitBtn = document.getElementById('submit-beer');

    if (!currentUser || !nameInput.value) return;

    try {
      if (submitBtn) submitBtn.textContent = 'Adding...';
      
      const { error } = await supabase
        .from('beers')
        .insert({
          user_id: currentUser.id,
          name: nameInput.value,
          notes: notesInput.value,
        });

      if (error) throw error;
      
      addBeerForm.reset();
      loadBeers();
    } catch (err) {
      alert('Error adding drink. Please try again.');
    } finally {
      if (submitBtn) submitBtn.textContent = 'Add to Tab';
    }
  });

  // Handle Repeat Button
  beerListEl?.addEventListener('click', async (e) => {
    const target = (e.target as Element).closest('.btn-repeat');
    if (!target || !currentUser) return;
    
    const name = target.getAttribute('data-name');
    const notes = target.getAttribute('data-notes');
    const originalContent = target.innerHTML;
    
    try {
      target.textContent = 'Adding...';
      const { error } = await supabase
        .from('beers')
        .insert({
          user_id: currentUser.id,
          name: name,
          notes: notes,
        });

      if (error) throw error;
      loadBeers();
    } catch (err) {
      alert('Error adding drink. Please try again.');
      target.innerHTML = originalContent;
    }
  });

  // Handle Logout
  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  init();
</script>

<style>
  .user-dashboard {
    padding-top: 2rem;
    padding-bottom: 4rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 1rem;
  }

  .header-left h2 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .user-email {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }

  .actions-panel {
    padding: 1.5rem;
  }

  .actions-panel h3 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .w-full {
    width: 100%;
  }

  .history-panel h3 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .badge {
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .badge-success {
    background-color: rgba(16, 185, 129, 0.15);
    color: var(--success);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .badge-warning {
    background-color: var(--brand-primary-light);
    color: var(--brand-primary);
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  /* Grouped View Styles */
  .beer-section { 
    display: flex; 
    flex-direction: column; 
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .beer-section.section-divider {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 1.5rem;
  }
  .beer-section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0 0.5rem;
    margin-bottom: 0.25rem;
  }
  .unpaid-label { color: var(--brand-primary); }
  .paid-label { color: var(--text-secondary); }

  .beer-group-container {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .group-header {
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .group-header:hover {
    background: rgba(255, 255, 255, 0.08);
  }
  .group-header.is-expanded .chevron-icon {
    transform: rotate(180deg);
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
  }

  .chevron-icon {
    transition: transform 0.3s ease;
    opacity: 0.5;
  }

  .group-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .beer-qty {
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--brand-primary);
  }

  .expand-hint {
    font-size: 0.8rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .beer-group-items {
    padding-left: 1rem;
    border-left: 2px solid rgba(255, 255, 255, 0.05);
    margin-left: 1.5rem;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .individual-beer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .item-meta {
    display: flex;
    flex-direction: column;
  }

  .item-time {
    font-size: 0.85rem;
    color: #fff;
  }

  .item-actions {
    display: flex;
    gap: 0.5rem;
  }

  .empty-state {
    padding: 3rem 2rem;
    color: var(--text-secondary);
  }

  .empty-icon {
    color: var(--bg-elevated);
    margin-bottom: 1rem;
  }
</style>
