---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Tab">
  <div class="container user-dashboard">
    <header class="dashboard-header animate-fade-in">
      <div class="header-left">
        <h2 id="user-display-name">My Tab</h2>
        <div class="user-meta-sub">
          <p class="user-email" id="user-email" role="status" aria-live="polite">Loading…</p>
          <button id="edit-profile-btn" class="btn-text-link">Edit Name</button>
        </div>
      </div>
      <button id="logout-btn" class="btn-secondary btn-sm">Sign Out</button>
    </header>

    <!-- Profile Modal -->
    <div
      id="profile-modal"
      class="modal-overlay"
      style="display: none;"
      role="dialog"
      aria-modal="true"
      aria-labelledby="profile-modal-title"
    >
      <div class="modal-content glass-panel animate-scale-up">
        <div class="modal-header">
          <h3 id="profile-modal-title">My Profile</h3>
          <button
            id="close-profile-modal"
            class="btn-icon"
            type="button"
            aria-label="Close profile modal"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <form id="profile-form" class="edit-form">
          <div class="input-group">
            <label for="profile-name" class="input-label">Your Name</label>
            <input
              type="text"
              id="profile-name"
              class="input-field"
              placeholder="How should we call you?"
              required
              autocomplete="name"
            >
          </div>
          <div class="modal-actions">
            <div class="flex-grow"></div>
            <button type="submit" class="btn-primary btn-sm">Save Profile</button>
          </div>
        </form>
      </div>
    </div>

    <div class="actions-panel glass-panel animate-fade-in" style="animation-delay: 0.1s;">
      <h3>Add a Drink</h3>
      <form id="add-beer-form" class="add-beer-form">
        <div class="input-group beer-search-shell">
          <label for="beer-name" class="input-label">What are you drinking?</label>
          <input
            type="text"
            id="beer-name"
            class="input-field"
            placeholder="Search the bottle shop list or type your own…"
            autocomplete="off"
            required
          >
          <div id="beer-selection-meta" class="beer-selection-meta" hidden></div>
          <div id="beer-search-results" class="beer-search-results" hidden></div>
          <p id="beer-search-status" class="beer-search-status">
            Start typing to search the local beer list. You can still add a custom beer name if nothing matches.
          </p>
        </div>
        
        <div class="input-group">
          <label for="beer-notes" class="input-label">Notes (optional)</label>
          <textarea id="beer-notes" class="input-field" placeholder="How is it?" autocomplete="off"></textarea>
        </div>

        <button type="submit" id="submit-beer" class="btn-primary w-full">
          Add to Tab
        </button>
      </form>
    </div>

    <div class="history-panel animate-fade-in" style="animation-delay: 0.2s;">
      <div class="history-header">
        <h3>My Tab</h3>
        <div id="day-navigator" class="day-navigator" hidden>
          <button type="button" id="day-prev" class="day-nav-btn day-prev" title="Previous day" aria-label="Previous day">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <div class="day-label-wrap">
            <span id="day-label" class="day-label">Today</span>
            <select id="day-select" class="day-select" aria-label="Select day">
              <option value="">Today</option>
            </select>
          </div>
          <button type="button" id="day-next" class="day-nav-btn day-next" title="Next day" aria-label="Next day">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </div>
      <div id="beer-list" class="beer-list">
        <div class="loading-state" role="status" aria-live="polite">Loading your drinks…</div>
      </div>
    </div>

    <!-- Profile Modal (Existing) -->
    <!-- ... stays as is ... -->

    <!-- Beer Edit Modal -->
    <div
      id="beer-edit-modal"
      class="modal-overlay"
      style="display: none;"
      role="dialog"
      aria-modal="true"
      aria-labelledby="beer-edit-modal-title"
    >
      <div class="modal-content glass-panel animate-scale-up">
        <div class="modal-header">
          <h3 id="beer-edit-modal-title">Edit Drink</h3>
          <button id="close-beer-modal" class="btn-icon" type="button" aria-label="Close edit drink modal">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <form id="beer-edit-form" class="edit-form">
          <input type="hidden" id="edit-beer-id">
          <div class="input-group">
            <label for="edit-beer-name" class="input-label">Drink Name</label>
            <input type="text" id="edit-beer-name" class="input-field" readonly style="opacity: 0.6; cursor: not-allowed;">
          </div>
          <div class="input-group">
            <label for="edit-beer-notes" class="input-label">Notes</label>
            <textarea id="edit-beer-notes" class="input-field" rows="3" autocomplete="off"></textarea>
          </div>
          <div class="checkbox-group">
            <input type="checkbox" id="edit-beer-paid" class="checkbox-input">
            <label for="edit-beer-paid" class="checkbox-label">Mark as Paid</label>
          </div>
          <div class="modal-actions">
            <button type="button" id="delete-beer-btn" class="btn-danger-outline btn-sm">Delete</button>
            <div class="flex-grow"></div>
            <button type="submit" class="btn-primary btn-sm">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  import type { BeerCatalogEntry } from '../data/beerCatalog.ts';
  import { beerCatalog } from '../data/beerCatalog.ts';
  import { clearBeerCatalogResults } from '../lib/beerCatalogResults.ts';
  import { escapeHtml } from '../lib/escapeHtml';
  import { getBeerCatalogInputMode } from '../lib/beerCatalogInputMode.ts';
  import { searchBeerCatalog } from '../lib/beerCatalogSearch.ts';
  import { supabase } from '../lib/supabase';

  let currentUser: any = null;
  let currentSearchResults: BeerCatalogEntry[] = [];
  let selectedBeer: BeerCatalogEntry | null = null;
  let catalogFromStock: BeerCatalogEntry[] = beerCatalog;
  let beerSearchTimer: number | undefined;
  let allBeers: any[] = [];
  let availableDays: string[] = [];
  let selectedDayKey: string = '';

  const userEmailEl = document.getElementById('user-email');
  const userDisplayNameEl = document.getElementById('user-display-name');
  const logoutBtn = document.getElementById('logout-btn');
  const addBeerForm = document.getElementById('add-beer-form') as HTMLFormElement;
  const beerNameInput = document.getElementById('beer-name') as HTMLInputElement;
  const beerNotesInput = document.getElementById('beer-notes') as HTMLTextAreaElement;
  const submitBeerBtn = document.getElementById('submit-beer') as HTMLButtonElement | null;
  const beerListEl = document.getElementById('beer-list');
  const dayNavigatorEl = document.getElementById('day-navigator');
  const dayLabelEl = document.getElementById('day-label');
  const daySelectEl = document.getElementById('day-select') as HTMLSelectElement | null;
  const dayPrevBtn = document.getElementById('day-prev');
  const dayNextBtn = document.getElementById('day-next');
  const beerSearchResultsEl = document.getElementById('beer-search-results');
  const beerSearchStatusEl = document.getElementById('beer-search-status');
  const beerSelectionMetaEl = document.getElementById('beer-selection-meta');
  const editProfileBtn = document.getElementById('edit-profile-btn');
  const profileModal = document.getElementById('profile-modal') as HTMLElement;
  const profileForm = document.getElementById('profile-form') as HTMLFormElement;
  const profileNameInput = document.getElementById('profile-name') as HTMLInputElement;
  const closeProfileModal = document.getElementById('close-profile-modal');

  // Load User & Data
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    
    if (!session) {
      window.location.href = '/login';
      return;
    }

    currentUser = session.user;
    if (userEmailEl) userEmailEl.textContent = currentUser.email;

    // Check role, if manager redirect to manager page
    let { data: profile, error: profileError } = await supabase
      .from('profiles')
      .select('role, full_name')
      .eq('id', currentUser.id)
      .maybeSingle();

    // FALLBACK: If profile is missing (OAuth delay or trigger fail), create it now
    if (!profile && !profileError) {
      console.log('[Auth] Profile missing, attempting fallback creation...');
      const fallbackName = currentUser.user_metadata?.full_name || currentUser.user_metadata?.name || '';
      
      const { data: newProfile, error: createError } = await supabase
        .from('profiles')
        .insert({
          id: currentUser.id,
          email: currentUser.email,
          full_name: fallbackName,
          role: 'customer'
        })
        .select()
        .single();
      
      if (createError) {
        console.error('[Auth] Fallback profile creation failed:', createError);
      } else {
        console.log('[Auth] Fallback profile created successfully');
        profile = newProfile;
      }
    }

    if (profile?.full_name && userDisplayNameEl) {
      userDisplayNameEl.textContent = profile.full_name;
    }

    if (profile?.role === 'manager') {
      window.location.href = '/manager';
      return;
    }

    await loadBeerStock();
    loadBeers();

    // Subscribe to real-time changes for this user's beers
    console.log('[Realtime] Setting up subscription for user:', currentUser.id);
    
    supabase
      .channel('customer-beers-' + currentUser.id)
      .on(
        'postgres_changes',
        { 
          event: '*', 
          schema: 'public', 
          table: 'beers' 
          // filter: `user_id=eq.${currentUser.id}` // TEMPORARILY DISABLED FILTER TO DEBUG
        },
        (payload) => {
          console.log('[Realtime] Beer change payload received:', payload);
          // Only reload if the change belongs to the current user
          const record = (payload.new as any)?.user_id ? payload.new as any : payload.old as any;
          if (record && record.user_id === currentUser?.id) {
            console.log('[Realtime] Data matches current user. Reloading...');
            loadBeers();
          }
        }
      )
      .subscribe((status, err) => {
        console.log('[Realtime] Subscription status:', status);
        if (err) console.error('[Realtime] Subscription error:', err);
      });

    // Beer Edit Modal Elements
    const beerModal = document.getElementById('beer-edit-modal') as HTMLElement;
    const beerForm = document.getElementById('beer-edit-form') as HTMLFormElement;
    const beerIdInput = document.getElementById('edit-beer-id') as HTMLInputElement;
    const beerNameInput = document.getElementById('edit-beer-name') as HTMLInputElement;
    const beerNotesInput = document.getElementById('edit-beer-notes') as HTMLTextAreaElement;
    const beerPaidInput = document.getElementById('edit-beer-paid') as HTMLInputElement;
    const closeBeerModal = document.getElementById('close-beer-modal');
    const deleteBeerBtn = document.getElementById('delete-beer-btn');

    // Handle Beer Edit Logic (Delegated)
    beerListEl?.addEventListener('click', (e) => {
      const editBtn = (e.target as Element).closest('.btn-edit-beer');
      if (!editBtn) return;

      const id = editBtn.getAttribute('data-id') ?? '';
      const name = editBtn.getAttribute('data-name') ?? '';
      const notes = editBtn.getAttribute('data-notes') ?? '';
      const isPaid = editBtn.getAttribute('data-paid') === 'true';

      beerIdInput.value = id;
      beerNameInput.value = name;
      beerNotesInput.value = notes;
      beerPaidInput.checked = isPaid;
      beerModal.style.display = 'flex';
    });

    closeBeerModal?.addEventListener('click', () => {
      beerModal.style.display = 'none';
    });

    beerForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = beerIdInput.value;
      const notes = beerNotesInput.value;
      const is_paid = beerPaidInput.checked;

      try {
        const { error } = await supabase
          .from('beers')
          .update({ notes, is_paid })
          .eq('id', id);

        if (error) throw error;
        beerModal.style.display = 'none';
        loadBeers();
      } catch (err) {
        alert('Error updating drink');
      }
    });

    deleteBeerBtn?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete this drink?')) return;
      const id = beerIdInput.value;
      try {
        const { error } = await supabase.from('beers').delete().eq('id', id);
        if (error) throw error;
        beerModal.style.display = 'none';
        loadBeers();
      } catch (err) {
        alert('Error deleting drink');
      }
    });

    // Profile Modal Logic
    editProfileBtn?.addEventListener('click', () => {
      if (userDisplayNameEl?.textContent && userDisplayNameEl.textContent !== 'My Tab') {
        profileNameInput.value = userDisplayNameEl.textContent;
      }
      profileModal.style.display = 'flex';
    });

    closeProfileModal?.addEventListener('click', () => {
      profileModal.style.display = 'none';
    });

    profileForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const newName = profileNameInput.value.trim();
      if (!newName) return;

      const { error } = await supabase
        .from('profiles')
        .update({ full_name: newName })
        .eq('id', currentUser.id);

      if (error) {
        alert('Error updating profile');
      } else {
        if (userDisplayNameEl) userDisplayNameEl.textContent = newName;
        profileModal.style.display = 'none';
      }
    });

    // Day navigation
    dayPrevBtn?.addEventListener('click', () => {
      const idx = availableDays.indexOf(selectedDayKey);
      if (idx < availableDays.length - 1) {
        selectedDayKey = availableDays[idx + 1];
        updateDayUI();
        renderBeerList(selectedDayKey);
      }
    });
    dayNextBtn?.addEventListener('click', () => {
      const idx = availableDays.indexOf(selectedDayKey);
      if (idx > 0) {
        selectedDayKey = availableDays[idx - 1];
        updateDayUI();
        renderBeerList(selectedDayKey);
      }
    });
    daySelectEl?.addEventListener('change', () => {
      const val = daySelectEl.value;
      if (val && availableDays.includes(val)) {
        selectedDayKey = val;
        updateDayUI();
        renderBeerList(selectedDayKey);
      }
    });
  }

  async function loadBeerStock() {
    try {
      const { data, error } = await supabase
        .from('beer_stock')
        .select('brewery, name, style, year')
        .eq('is_unavailable', false)
        .order('name', { ascending: true });

      if (error) {
        console.error('[Catalog] Failed to load beer_stock from Supabase, falling back to static catalog.', error);
        catalogFromStock = beerCatalog;
        return;
      }

      catalogFromStock = (data ?? []).map((row: any) => ({
        brewery: row.brewery ?? '',
        name: row.name ?? '',
        style: row.style ?? '',
        year: row.year ?? 'N/A',
      })) as BeerCatalogEntry[];
    } catch (err) {
      console.error('[Catalog] Unexpected error loading beer_stock, falling back to static catalog.', err);
      catalogFromStock = beerCatalog;
    }
  }

  function renderCatalogSearchResults(query: string) {
    currentSearchResults = searchBeerCatalog(catalogFromStock, query);

    if (!beerSearchResultsEl) return;

    if (currentSearchResults.length === 0) {
      beerSearchResultsEl.innerHTML = '';
      beerSearchResultsEl.hidden = true;
      setSearchStatus(`No catalog matches for "${query}". You can still add it manually.`);
      return;
    }

    beerSearchResultsEl.innerHTML = currentSearchResults
      .map((beer, index) => {
        const yearLabel = beer.year === 'N/A' ? '' : ` · ${escapeHtml(beer.year)}`;
        return `
          <button type="button" class="beer-search-option" data-result-index="${index}">
            <span class="beer-search-option-title">${escapeHtml(beer.name)}</span>
            <span class="beer-search-option-meta">${escapeHtml(beer.brewery)} · ${escapeHtml(beer.style)}${yearLabel}</span>
          </button>
        `;
      })
      .join('');

    beerSearchResultsEl.hidden = false;
    setSearchStatus(`Showing ${currentSearchResults.length} match${currentSearchResults.length === 1 ? '' : 'es'} from the local catalog.`);
  }

  function setSelectedBeer(beer: BeerCatalogEntry | null) {
    selectedBeer = beer;

    if (!beerSelectionMetaEl) return;

    if (!beer) {
      beerSelectionMetaEl.hidden = true;
      beerSelectionMetaEl.textContent = '';
      return;
    }

    const yearLabel = beer.year === 'N/A' ? '' : ` · ${beer.year}`;
    beerSelectionMetaEl.textContent = `${beer.brewery} · ${beer.style}${yearLabel}`;
    beerSelectionMetaEl.hidden = false;
  }

  function hideSearchResults() {
    clearBeerCatalogResults(beerSearchResultsEl);
  }

  function setSearchStatus(message: string) {
    if (beerSearchStatusEl) {
      beerSearchStatusEl.textContent = message;
    }
  }

  function getDateKey(d: Date): string {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  function getTodayKey(): string {
    return getDateKey(new Date());
  }

  function formatDayLabel(key: string): string {
    const today = getTodayKey();
    if (key === today) return 'Today';
    const d = new Date(key + 'T12:00:00');
    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    if (getDateKey(yesterday) === key) return 'Yesterday';
    return d.toLocaleDateString([], { weekday: 'short', month: 'short', day: 'numeric' });
  }

  function updateDayUI() {
    if (dayLabelEl) dayLabelEl.textContent = formatDayLabel(selectedDayKey);
    if (daySelectEl) {
      daySelectEl.innerHTML = availableDays
        .map(k => `<option value="${escapeHtml(k)}"${k === selectedDayKey ? ' selected' : ''}>${escapeHtml(formatDayLabel(k))}</option>`)
        .join('');
      daySelectEl.value = selectedDayKey;
    }
    if (dayPrevBtn) {
      const idx = availableDays.indexOf(selectedDayKey);
      dayPrevBtn.setAttribute('aria-disabled', idx >= availableDays.length - 1 ? 'true' : 'false');
      (dayPrevBtn as HTMLButtonElement).disabled = idx >= availableDays.length - 1;
    }
    if (dayNextBtn) {
      const idx = availableDays.indexOf(selectedDayKey);
      dayNextBtn.setAttribute('aria-disabled', idx <= 0 ? 'true' : 'false');
      (dayNextBtn as HTMLButtonElement).disabled = idx <= 0;
    }
  }

  async function loadBeers() {
    if (!beerListEl || !currentUser) return;

    const { data, error } = await supabase
      .from('beers')
      .select('*')
      .eq('user_id', currentUser.id)
      .order('created_at', { ascending: false });

    if (error) {
      beerListEl.innerHTML = `<div class="error-state">Failed to load drinks</div>`;
      if (dayNavigatorEl) dayNavigatorEl.hidden = true;
      return;
    }

    allBeers = data ?? [];
    const daySet = new Set<string>();
    allBeers.forEach(b => daySet.add(getDateKey(new Date(b.created_at))));
    daySet.add(getTodayKey());
    availableDays = Array.from(daySet).sort().reverse();
    if (availableDays.length > 0 && !selectedDayKey) selectedDayKey = getTodayKey();
    if (availableDays.length > 0 && !availableDays.includes(selectedDayKey)) selectedDayKey = availableDays[0];

    if (dayNavigatorEl) dayNavigatorEl.hidden = availableDays.length === 0;
    updateDayUI();
    renderBeerList(selectedDayKey);
  }

  function renderBeerList(dayKey: string) {
    if (!beerListEl) return;

    const dayBeers = allBeers.filter(b => getDateKey(new Date(b.created_at)) === dayKey);

    type GroupData = { name: string; notes: string; items: any[]; is_paid: boolean; };
    const groups: Record<string, GroupData> = {};
    dayBeers.forEach(b => {
      const key = `${b.name.toLowerCase()}::${b.is_paid}`;
      if (groups[key]) {
        groups[key].items.push(b);
      } else {
        groups[key] = { name: b.name, notes: b.notes || '', items: [b], is_paid: b.is_paid };
      }
    });

    const groupList = Object.values(groups).sort((a, b) => {
      if (a.is_paid === b.is_paid) return 0;
      return a.is_paid ? 1 : -1;
    });
    const unpaidGroups = groupList.filter(g => !g.is_paid);
    const paidGroups = groupList.filter(g => g.is_paid);

    const renderGroup = (g: GroupData, groupIndex: number, sectionType: string) => {
      const groupId = `group-customer-${sectionType}-${groupIndex}`;
      const safeGroupName = escapeHtml(g.name);
      const safeGroupNotes = escapeHtml(g.notes || 'Click to see details');
      const safeNameAttr = escapeHtml(g.name);
      const safeNotesAttr = escapeHtml(g.notes || '');
      return `
      <div class="beer-group-container" id="${groupId}">
        <div class="beer-item beer-card glass-panel ${g.is_paid ? 'paid' : 'unpaid'} group-header" data-toggle-group="${groupId}">
          <div class="beer-content">
            <div class="beer-info">
              <div class="beer-title-row">
                <h4>${safeGroupName}</h4>
                <div class="header-status">
                  ${!g.is_paid ? `<button type="button" class="btn-add-one" data-name="${safeNameAttr}" data-notes="${safeNotesAttr}" title="Add another" aria-label="Add another drink">+1</button>` : ''}
                  ${g.is_paid 
                    ? `<span class="badge badge-success">Paid</span>` 
                    : `<span class="badge badge-warning">On Tab</span>`
                  }
                  <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </div>
              </div>
              <div class="group-meta">
                <span class="beer-qty">×${g.items.length}</span>
                <span class="expand-hint">${safeGroupNotes}</span>
              </div>
            </div>
          </div>
        </div>
        <div class="beer-group-items" style="display: none;">
          ${g.items.map(item => {
            const safeName = escapeHtml(item.name || 'Drink');
            const safeNotes = escapeHtml(item.notes || '');
            const dateStr = new Date(item.created_at).toLocaleDateString([], { month: 'short', day: 'numeric' })
              + ' ' + new Date(item.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            return `
            <div class="individual-beer-row glass-panel" data-id="${item.id}">
              <div class="item-meta">
                <span class="item-time">${dateStr}</span>
              </div>
              <div class="item-actions">
                <button type="button" class="btn-icon btn-edit-beer" aria-label="Edit drink"
                        data-id="${item.id}" 
                        data-name="${safeName}" 
                        data-notes="${safeNotes}" 
                        data-paid="${item.is_paid}"
                        title="Edit drink">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                </button>
                <button type="button" class="btn-icon btn-repeat" aria-label="Add another drink" data-name="${safeName}" data-notes="${safeNotes}" title="Add another">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </button>
              </div>
            </div>`;
          }).join('')}
        </div>
      </div>`;
    };

    beerListEl.innerHTML = `
      ${unpaidGroups.length > 0 ? `
        <div class="beer-section">
          <div class="beer-section-label unpaid-label">On Tab</div>
          ${unpaidGroups.map((g, i) => renderGroup(g, i, 'unpaid')).join('')}
        </div>` : ''}
      ${paidGroups.length > 0 ? `
        <div class="beer-section ${unpaidGroups.length > 0 ? 'section-divider' : ''}">
          <div class="beer-section-label paid-label">Paid</div>
          ${paidGroups.map((g, i) => renderGroup(g, i, 'paid')).join('')}
        </div>` : ''}
      ${dayBeers.length === 0 ? `
        <div class="empty-state glass-panel text-center">
          <p>${dayKey === getTodayKey() ? 'Your tab is empty! Time to grab a drink.' : 'No drinks for this day.'}</p>
        </div>` : ''}
    `;

    // Add Expand/Collapse Event Listeners
    beerListEl.querySelectorAll('.group-header').forEach(header => {
      header.setAttribute('role', 'button');
      header.setAttribute('tabindex', '0');
      header.setAttribute('aria-expanded', 'false');

      header.addEventListener('click', (e) => {
        // Don't toggle if clicking an action button (though we don't have many here)
        if ((e.target as HTMLElement).closest('.btn-icon, .btn-add-one')) return;
        
        const groupId = header.getAttribute('data-toggle-group');
        if (!groupId) return;
        const groupContainer = document.getElementById(groupId);
        const itemsList = groupContainer?.querySelector('.beer-group-items') as HTMLElement;
        if (itemsList) {
          const isHidden = itemsList.style.display === 'none';
          itemsList.style.display = isHidden ? 'flex' : 'none';
          header.classList.toggle('is-expanded', isHidden);
          header.setAttribute('aria-expanded', String(isHidden));
        }
      });

      header.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        if (key !== 'Enter' && key !== ' ') return;

        // Don't toggle if keyboard focus is on an action inside the header
        if ((e.target as HTMLElement)?.closest('.btn-icon, .btn-add-one')) return;

        e.preventDefault();
        (header as HTMLElement).click();
      });
    });
  }

  // Handle Add Drink
  addBeerForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const drinkName = selectedBeer?.name ?? beerNameInput.value.trim();

    if (!currentUser || !drinkName) return;

    try {
      if (submitBeerBtn) {
        submitBeerBtn.textContent = 'Adding…';
        submitBeerBtn.disabled = true;
        submitBeerBtn.setAttribute('aria-busy', 'true');
      }
      
      const { error } = await supabase
        .from('beers')
        .insert({
          user_id: currentUser.id,
          name: drinkName,
          notes: beerNotesInput.value,
        });

      if (error) throw error;
      
      addBeerForm.reset();
      setSelectedBeer(null);
      currentSearchResults = [];
      hideSearchResults();
      setSearchStatus('Start typing to search the local beer list. You can still add a custom beer name if nothing matches.');
      loadBeers();
    } catch (err) {
      alert('Error adding drink. Please try again.');
    } finally {
      if (submitBeerBtn) submitBeerBtn.textContent = 'Add to Tab';
      if (submitBeerBtn) {
        submitBeerBtn.disabled = false;
        submitBeerBtn.removeAttribute('aria-busy');
      }
    }
  });

  beerNameInput?.addEventListener('input', (event) => {
    const query = beerNameInput.value.trim();
    const inputMode = getBeerCatalogInputMode(
      query,
      event instanceof InputEvent ? event.inputType : undefined,
    );

    if (!selectedBeer || selectedBeer.name !== query) {
      setSelectedBeer(null);
    }

    if (beerSearchTimer !== undefined) {
      window.clearTimeout(beerSearchTimer);
    }

    if (inputMode === 'hide') {
      currentSearchResults = [];
      hideSearchResults();
      setSearchStatus('Start typing to search the local beer list. You can still add a custom beer name if nothing matches.');
      return;
    }

    if (inputMode === 'immediate') {
      renderCatalogSearchResults(query);
      return;
    }

    beerSearchTimer = window.setTimeout(() => {
      renderCatalogSearchResults(query);
    }, 200);
  });

  beerSearchResultsEl?.addEventListener('click', (e) => {
    const target = (e.target as HTMLElement).closest('.beer-search-option');

    if (!target) return;

    const resultIndex = Number(target.getAttribute('data-result-index'));
    const beer = currentSearchResults[resultIndex];

    if (!beer) return;

    beerNameInput.value = beer.name;
    setSelectedBeer(beer);
    hideSearchResults();
    setSearchStatus('Catalog selection locked in. You can keep typing to switch back to a custom name.');
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    if (!target.closest('.beer-search-shell')) {
      hideSearchResults();
    }
  });

  function getDecodedAttribute(el: Element, attr: string): string {
    const raw = el.getAttribute(attr) ?? '';
    const text = document.createElement('span');
    text.innerHTML = raw;
    return text.textContent ?? raw;
  }

  // Handle +1 button on beer card (add another of same drink)
  beerListEl?.addEventListener('click', async (e) => {
    const target = (e.target as Element).closest('.btn-add-one');
    if (!target || !currentUser) return;
    e.stopPropagation();

    const name = getDecodedAttribute(target, 'data-name');
    const notes = getDecodedAttribute(target, 'data-notes');
    const btn = target as HTMLButtonElement;
    const originalText = btn.textContent ?? '+1';

    try {
      btn.textContent = 'Adding…';
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
      const { error } = await supabase
        .from('beers')
        .insert({
          user_id: currentUser.id,
          name,
          notes,
        });

      if (error) throw error;
      loadBeers();
    } catch (err) {
      alert('Error adding drink. Please try again.');
      btn.textContent = originalText;
    } finally {
      btn.disabled = false;
      btn.removeAttribute('aria-busy');
      btn.textContent = originalText;
    }
  });

  // Handle Repeat Button (inside expanded list)
  beerListEl?.addEventListener('click', async (e) => {
    const target = (e.target as Element).closest('.btn-repeat');
    if (!target || !currentUser) return;
    
    const name = getDecodedAttribute(target, 'data-name');
    const notes = getDecodedAttribute(target, 'data-notes');
    const btn = target as HTMLButtonElement;
    const originalContent = btn.innerHTML;
    
    try {
      btn.textContent = 'Adding…';
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
      const { error } = await supabase
        .from('beers')
        .insert({
          user_id: currentUser.id,
          name,
          notes,
        });

      if (error) throw error;
      loadBeers();
    } catch (err) {
      alert('Error adding drink. Please try again.');
    } finally {
      btn.disabled = false;
      btn.removeAttribute('aria-busy');
      btn.innerHTML = originalContent;
    }
  });

  // Handle Logout
  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  init();
</script>

